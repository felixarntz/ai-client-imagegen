{
    "name": "felixarntz/ai-client-imagegen",
    "description": "This WordPress plugin is a demo plugin for using the WordPress built-in AI Client launching in WordPress 7.0.",
    "license": "GPL-2.0-or-later",
	"type": "wordpress-plugin",
    "keywords": [
        "ai",
        "client",
        "image generation",
        "media library"
    ],
    "authors": [
        {
            "name": "Felix Arntz",
            "homepage": "https://felix-arntz.me"
        }
    ],
    "homepage": "https://github.com/felixarntz/ai-client-imagegen",
    "support": {
        "issues": "https://github.com/felixarntz/ai-client-imagegen/issues",
        "source": "https://github.com/felixarntz/ai-client-imagegen"
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpstan/phpstan": "~2.1",
        "slevomat/coding-standard": "^8.20",
        "squizlabs/php_codesniffer": "^3.7 || ^4.0",
		"szepeviktor/phpstan-wordpress": "^2.0",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
			"composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "optimize-autoloader": true,
        "platform": {
            "php": "7.4"
        },
        "sort-packages": true
    },
    "scripts": {
        "phpcbf": "phpcbf",
        "phpcs": "phpcs",
        "phpstan": "phpstan analyze --memory-limit=512M"
    }
}
